  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n参謀総長、参謀次長、陸軍大将"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n陸相、陸軍次官、朝鮮総督、陸軍大将"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

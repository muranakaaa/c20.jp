    "class": "name"
   },
   "html": "\n[ かざみ・あきら ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n法相、内閣書記官長、社会党日中国交回復国民会議理事長、新聞記者"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

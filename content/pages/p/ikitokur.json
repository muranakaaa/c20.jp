   "html": "\n[ いちき・きとくろう ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n内相、文相、宮内大臣、枢密院議長、内務次官、法制局長官、東大教授"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

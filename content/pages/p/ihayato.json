  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n首相、蔵相、通産相、自民党総裁、自由党幹事長、大蔵事務次官"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

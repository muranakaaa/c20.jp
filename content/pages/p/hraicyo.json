   "html": "\n[ ひらつか・らいちょう ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n女性解放運動家、日本婦人団体連盟会長、国際民主婦人連盟副会長"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n教育総監、航空総監、奉天特務機関長、奉天市長、陸軍大将、Ａ級戦犯"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

    "class": "name"
   },
   "html": "\n[ もり・かく（つとむ） ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n内閣書記官長、外務政務次官、政友会幹事長、三井物産天津支店長"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

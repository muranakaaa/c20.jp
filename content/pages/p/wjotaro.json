  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "name"
   },
   "html": "\n[ わたなべ・じょうたろう ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n教育総監、参謀本部第四部長、陸大校長、陸軍大将"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

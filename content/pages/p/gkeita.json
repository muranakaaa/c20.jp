   "html": "\n[ ごとう・けいた ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n運輸通信相、実業家、東急電鉄会長"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

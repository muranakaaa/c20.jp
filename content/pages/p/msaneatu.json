  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "name"
   },
   "html": "\n[ むしゃのこうじ・さねあつ ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n小説家、画家、貴族院議員、武者小路公共の弟"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

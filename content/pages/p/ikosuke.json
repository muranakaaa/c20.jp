       "id": "l",
       "cls": null,
       "html": "1904/02/10　　<a href=\"../1904/02jr_wa.html\">\n対露宣戦布告</a>　（<a href=\"../them/jr_war.html\">日露戦争</a>勃発）"
      }
     ]
    },
    {
     "cls": "n",
     "cells": [

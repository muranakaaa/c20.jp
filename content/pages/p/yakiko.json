   "html": "\n[ よさの・あきこ ]"
  },
  {
   "type": "raw",
   "tag": "div",
   "attrs": {
    "class": "prof"
   },
   "html": "\n歌人、詩人、与謝野鉄幹の妻"
  },
  {
   "type": "raw",
   "tag": "table",
   "attrs": {

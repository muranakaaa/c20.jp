td class=\"tb\"><a href=\"../1941/kono3_1~.html\">近衛内閣③</a></td>\n</tr><tr>\n<td class=\"tb\"><a href=\"../1941/tojo_1~.html\">東條内閣</a></td>\n<td class=\"tb\"><a href=\"../1944/koiso_1~.html\">小磯内閣</a></td>\n<td class=\"tb\"><a href=\"../1945/suzua_1~.html\">鈴木（貫）内閣</a></td>\n<td class=\"tb\"><a href=\"../1945/higa_1~.html\">東久邇宮内閣</a></td>\n<td class=\"tb\"><a href=\"../1945/side_1~.html\">幣原内閣</a></td>\n</tr><tr>\n<td class=\"tb\"><a href=\"../1946/yosi1_1~.html\">吉田内閣①</a></td>\n<td class=\"tb\"><a href=\"../1947/kata_1~.html\">片山内閣</a></td>\n<td class=\"tb\"><a href=\"../1948/asi_1~.html\">芦田内閣</a></td>\n<td class=\"tb\"><a href=\"../1948/yosi2_1~.html\">吉田内閣②</a></td>\n<td class=\"tb\"><a href=\"../1949/yosi3_1~.html\">吉田内閣③</a></td>\n</tr></tbody>"

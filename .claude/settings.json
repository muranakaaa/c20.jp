{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun run ci)",
      "Bash(bun run build)",
      "Bash(bun run verify)",
      "Bash(bun run extract)",
      "Bash(bun run postprocess)",
      "Bash(bun test:*)",
      "Bash(bun run typecheck)",
      "Bash(bun run check:*)",
      "Bash(bun run fix:*)"
    ],
    "deny": [
      "Edit(original/**)",
      "Edit(content/**)",
      "Write(original/**)",
      "Write(content/**)",
      "Edit(dist/**)",
      "Write(dist/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-verify.sh\"",
            "statusMessage": "stop-verify: bun run ci の通過確認"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-deploy.sh\"",
            "statusMessage": "guard-deploy: デプロイ経路の確認"
          }
        ]
      }
    ]
  }
}

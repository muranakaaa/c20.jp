#!/usr/bin/env bash
# コミットメッセージ規約の強制。bun install 時に core.hooksPath がここを向く（package.json の prepare）。
# 規約: 日本語で1行・72字以内・種別/スコープ prefix 禁止・カッコ補足禁止・末尾句点なし
set -u
msg_file="$1"
subject=$(grep -v '^#' "$msg_file" | head -1)

# マージ・リバート・fixup は対象外
case "$subject" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

fail() {
  echo "commit-msg: $1" >&2
  echo "  対象: $subject" >&2
  exit 1
}

body=$(grep -v '^#' "$msg_file" | sed -n '2,$p' | grep -v '^[[:space:]]*$' || true)
[ -n "$body" ] && fail "1行で完結させる"

[ -z "$subject" ] && fail "メッセージが空"

echo "$subject" | grep -qE '^[A-Za-z0-9_-]+(\([^)]*\))?[:：]' && fail "種別/スコープのprefixを付けない"

echo "$subject" | grep -q '[（()）]' && fail "カッコで補足や理由を併記しない。本文に直接書くか別コミットに切る"

echo "$subject" | grep -q '。$' && fail "末尾に句点を付けない"

echo "$subject" | grep -q '[ぁ-んァ-ヶ一-龠]' || fail "日本語で書く"

[ "$(echo -n "$subject" | wc -m)" -gt 72 ] && fail "72字以内に収める"

exit 0

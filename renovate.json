{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":timezone(Asia/Tokyo)"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "更新の速い oxc / tsgo はまとめて週次で",
      "matchPackageNames": ["oxlint", "oxfmt", "@typescript/native-preview"],
      "groupName": "toolchain",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "mise で固定している bun 本体も追従する",
      "matchPackageNames": ["bun"],
      "groupName": "bun"
    }
  ]
}
